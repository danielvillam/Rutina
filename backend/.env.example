# ── Copia este archivo como .env y rellena tus valores ──

# MongoDB Atlas connection string
# Formato: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://USUARIO:PASSWORD@cluster0.xxxxx.mongodb.net/rutina_db?retryWrites=true&w=majority

# Nombre de la base de datos (ya incluido en la URI, pero se referencia aquí)
DB_NAME=rutina_db

# JWT secret — usa una cadena larga y aleatoria (mín 32 chars)
JWT_SECRET=cambia_esto_por_un_secreto_muy_largo_y_aleatorio_32chars

# Tiempo de expiración del token (7 días recomendado)
JWT_EXPIRES_IN=7d

# Puerto del servidor
PORT=3000

# Entorno
NODE_ENV=development

# URL pública del servicio (Render la inyecta automáticamente en producción)
# No necesitas configurar esto manualmente en Render
# RENDER_EXTERNAL_URL=https://tu-app.onrender.com

# URL del frontend si está en dominio separado (opcional)
# FRONTEND_URL=https://tu-dominio.com

